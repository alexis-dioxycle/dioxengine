# --- Core ---
# Public URL of the app (used for OAuth redirects). Local dev:
APP_URL=http://localhost:5006
JWT_SECRET=dev-secret-change-me-1234567890
ALLOWED_EMAIL_DOMAIN=dioxycle.com

# Local dev: no-password login (POST /auth/dev-login {email}). MUST be 0 in prod.
ALLOW_DEV_LOGIN=1

# --- Database ---
# Unset → SQLite at backend/data/dioxengine.db. Render injects DATABASE_URL.
# DATABASE_URL=postgresql://...

# --- Microsoft OAuth (web login + MCP authorize) ---
# Ask IT for an Entra app registration (redirect URI: $APP_URL/auth/microsoft/callback)
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# --- MCP connector (claude.ai) ---
# Any random strings; Claude gets them via /oauth/register. Unset locally →
# /mcp is open and tools run as the first user (dev only).
# MCP_CLIENT_ID=
# MCP_CLIENT_SECRET=
